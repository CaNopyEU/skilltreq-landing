---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import Features from '../../components/Features.astro';
import PWAInstall from '../../components/PWAInstall.astro';
import { useTranslations } from '../../i18n/translations';

const locale = 'sk';
const t = useTranslations(locale);

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'SoftwareApplication',
      name: 'SkillTreq',
      applicationCategory: 'HealthApplication',
      operatingSystem: 'Web',
      description: t('meta.description'),
      url: 'https://www.skilltreq.app',
      offers: {
        '@type': 'Offer',
        price: '0',
        priceCurrency: 'EUR',
      },
    },
    {
      '@type': 'Organization',
      name: 'SkillTreq',
      url: 'https://www.skilltreq.com',
      logo: 'https://www.skilltreq.com/logo.svg',
      contactPoint: {
        '@type': 'ContactPoint',
        email: 'hello@skilltreq.com',
        contactType: 'customer support',
      },
      sameAs: [],
    },
    {
      '@type': 'WebSite',
      name: 'SkillTreq',
      url: 'https://www.skilltreq.com',
      potentialAction: {
        '@type': 'SearchAction',
        target: 'https://www.skilltreq.com/?q={search_term_string}',
        'query-input': 'required name=search_term_string',
      },
    },
  ],
};
---

<BaseLayout
  title={t('meta.title')}
  description={t('meta.description')}
  locale={locale}
  currentPath="/"
  jsonLd={jsonLd}
>
  <Hero locale={locale} />
  <Features locale={locale} />
  <PWAInstall locale={locale} />
</BaseLayout>
