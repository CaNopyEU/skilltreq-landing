---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { Locale } from '../i18n/translations';
import { locales, getLocalizedPath } from '../i18n/translations';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  locale: Locale;
  currentPath: string;
  jsonLd?: Record<string, unknown>;
}

const { title, description, locale, currentPath, jsonLd } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl.href} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:site_name" content="Skilltreq" />
    <meta property="og:locale" content={locale} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- hreflang -->
    {
      locales.map((loc) => (
        <link
          rel="alternate"
          hreflang={loc}
          href={new URL(getLocalizedPath(loc, currentPath), Astro.site).href}
        />
      ))
    }
    <link
      rel="alternate"
      hreflang="x-default"
      href={new URL(getLocalizedPath('en', currentPath), Astro.site).href}
    />

    <!-- JSON-LD -->
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}

    <!-- Dark mode detection (inline to prevent FOUC) -->
    <script is:inline>
      (function () {
        const theme = localStorage.getItem('theme') || 'system';
        const isDark =
          theme === 'dark' ||
          (theme === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches);
        if (isDark) document.documentElement.classList.add('dark');
      })();
    </script>
  </head>
  <body class="min-h-dvh bg-page text-body antialiased">
    <Header locale={locale} currentPath={currentPath} />
    <main>
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
