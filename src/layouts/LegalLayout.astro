---
import BaseLayout from './BaseLayout.astro';
import type { Locale } from '../i18n/translations';

interface Props {
  title: string;
  description: string;
  locale: Locale;
  currentPath: string;
  lastUpdated: string;
}

const { title, description, locale, currentPath, lastUpdated } = Astro.props;
---

<BaseLayout title={title} description={description} locale={locale} currentPath={currentPath}>
  <article class="mx-auto max-w-3xl px-4 py-16 sm:px-6 sm:py-24">
    <header class="mb-10">
      <h1 class="text-3xl font-bold tracking-tight text-primary sm:text-4xl">{title}</h1>
      <p class="mt-2 text-sm text-text-muted">{lastUpdated}</p>
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>
