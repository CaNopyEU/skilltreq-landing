---
import type { Locale } from '../i18n/translations';
import { useTranslations } from '../i18n/translations';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<theme-toggle>
  <button
    type="button"
    aria-label="Toggle theme"
    class="flex items-center gap-0.5 rounded-lg border border-border bg-surface p-1 text-sm"
  >
    <span
      data-theme="light"
      class="rounded-md px-2 py-1 text-text-muted transition-colors hover:text-primary"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        ><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line
          x1="12"
          y1="21"
          x2="12"
          y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line
          x1="18.36"
          y1="18.36"
          x2="19.78"
          y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line
          x1="21"
          y1="12"
          x2="23"
          y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line
          x1="18.36"
          y1="5.64"
          x2="19.78"
          y2="4.22"></line></svg
      >
      <span class="sr-only">{t('theme.light')}</span>
    </span>
    <span
      data-theme="dark"
      class="rounded-md px-2 py-1 text-text-muted transition-colors hover:text-primary"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg
      >
      <span class="sr-only">{t('theme.dark')}</span>
    </span>
    <span
      data-theme="system"
      class="rounded-md px-2 py-1 text-text-muted transition-colors hover:text-primary"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        ><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line
          x1="8"
          y1="21"
          x2="16"
          y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg
      >
      <span class="sr-only">{t('theme.system')}</span>
    </span>
  </button>
</theme-toggle>

<script>
  class ThemeToggle extends HTMLElement {
    connectedCallback() {
      const buttons = this.querySelectorAll<HTMLElement>('[data-theme]');
      const update = (theme: string) => {
        localStorage.setItem('theme', theme);
        const isDark =
          theme === 'dark' ||
          (theme === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches);
        document.documentElement.classList.toggle('dark', isDark);
        buttons.forEach((btn) => {
          const isActive = btn.dataset.theme === theme;
          btn.classList.toggle('bg-hover', isActive);
          btn.classList.toggle('text-primary', isActive);
          btn.classList.toggle('text-text-muted', !isActive);
        });
      };

      const stored = localStorage.getItem('theme') || 'system';
      update(stored);

      buttons.forEach((btn) => {
        btn.addEventListener('click', () => update(btn.dataset.theme!));
      });

      window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
        if (localStorage.getItem('theme') === 'system') update('system');
      });
    }
  }
  customElements.define('theme-toggle', ThemeToggle);
</script>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
</style>
