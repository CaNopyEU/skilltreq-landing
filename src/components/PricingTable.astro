---
import type { Locale, TranslationKey } from '../i18n/translations';
import { useTranslations } from '../i18n/translations';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

type FeatureValue = true | false | string;

interface Tier {
  key: 'free' | 'pro' | 'coach';
  name: TranslationKey;
  price: TranslationKey;
  period: TranslationKey;
  cta: TranslationKey;
  highlighted?: boolean;
}

interface Feature {
  label: TranslationKey;
  free: FeatureValue;
  pro: FeatureValue;
  coach: FeatureValue;
}

const tiers: Tier[] = [
  {
    key: 'free',
    name: 'pricing.free.name',
    price: 'pricing.free.price',
    period: 'pricing.free.period',
    cta: 'pricing.free.cta',
  },
  {
    key: 'pro',
    name: 'pricing.pro.name',
    price: 'pricing.pro.price',
    period: 'pricing.pro.period',
    cta: 'pricing.pro.cta',
    highlighted: true,
  },
  {
    key: 'coach',
    name: 'pricing.coach.name',
    price: 'pricing.coach.price',
    period: 'pricing.coach.period',
    cta: 'pricing.coach.cta',
  },
];

const features: Feature[] = [
  {
    label: 'pricing.feature.libraries',
    free: 'pricing.value.all',
    pro: 'pricing.value.all',
    coach: 'pricing.value.all',
  },
  {
    label: 'pricing.feature.plans',
    free: 'pricing.value.one',
    pro: 'pricing.value.unlimited',
    coach: 'pricing.value.unlimited',
  },
  {
    label: 'pricing.feature.templates',
    free: 'pricing.value.three',
    pro: 'pricing.value.unlimited',
    coach: 'pricing.value.unlimited',
  },
  { label: 'pricing.feature.radar', free: true, pro: true, coach: true },
  { label: 'pricing.feature.heatmap', free: true, pro: true, coach: true },
  { label: 'pricing.feature.prTrends', free: false, pro: true, coach: true },
  { label: 'pricing.feature.journey', free: false, pro: true, coach: true },
  { label: 'pricing.feature.export', free: false, pro: true, coach: true },
  { label: 'pricing.feature.clients', free: false, pro: false, coach: true },
  { label: 'pricing.feature.dashboard', free: false, pro: false, coach: true },
];

function renderValue(val: FeatureValue): string {
  if (val === true) return '✓';
  if (val === false) return '—';
  return t(val as TranslationKey);
}

function cellClass(val: FeatureValue): string {
  if (val === false) return 'py-3 text-center text-text-muted';
  if (val === true) return 'py-3 text-center text-status-completed';
  return 'py-3 text-center text-primary';
}
---

<section class="py-20 sm:py-28">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="mx-auto max-w-2xl text-center">
      <h1 class="text-3xl font-bold tracking-tight text-primary sm:text-4xl">
        {t('pricing.heading')}
      </h1>
      <p class="mt-4 text-lg text-secondary">
        {t('pricing.subtitle')}
      </p>
    </div>

    <!-- Card layout -->
    <div class="mt-16 grid gap-8 lg:grid-cols-3">
      {
        tiers.map((tier) => (
          <div
            class:list={[
              'relative flex flex-col rounded-xl border p-6 sm:p-8',
              tier.highlighted
                ? 'border-accent bg-accent/5 shadow-lg shadow-accent/10'
                : 'border-border bg-surface',
            ]}
          >
            <h2 class="text-xl font-semibold text-primary">{t(tier.name)}</h2>
            <div class="mt-4 flex items-baseline gap-1">
              <span class="text-4xl font-bold text-primary">
                {t('pricing.currency')}
                {t(tier.price)}
              </span>
              <span class="text-sm text-text-muted">{t(tier.period)}</span>
            </div>

            <ul class="mt-8 flex-1 space-y-3">
              {features.map((feature) => {
                const val = feature[tier.key];
                if (val === false) return null;
                return (
                  <li class="flex items-center gap-2 text-sm text-body">
                    <span
                      class:list={[
                        'flex-shrink-0',
                        val === true ? 'text-status-completed' : 'text-accent',
                      ]}
                    >
                      {renderValue(val)}
                    </span>
                    <span>{t(feature.label)}</span>
                  </li>
                );
              })}
            </ul>

            <a
              href="https://www.skilltreq.app/login"
              class:list={[
                'mt-8 block text-center',
                tier.highlighted ? 'btn-primary' : 'btn-secondary',
              ]}
            >
              {t(tier.cta)}
            </a>
          </div>
        ))
      }
    </div>

    <!-- Feature comparison table (desktop) -->
    <div class="mt-20 hidden lg:block">
      <table class="w-full text-left text-sm">
        <thead>
          <tr class="border-b border-border">
            <th class="pb-4 pr-4 text-body font-medium"></th>
            {
              tiers.map((tier) => (
                <th
                  class={
                    tier.highlighted
                      ? 'pb-4 text-center font-semibold text-accent'
                      : 'pb-4 text-center font-semibold text-primary'
                  }
                >
                  {t(tier.name)}
                </th>
              ))
            }
          </tr>
        </thead>
        <tbody>
          {
            features.map((feature) => (
              <tr class="border-b border-border/50">
                <td class="py-3 pr-4 text-body">{t(feature.label)}</td>
                <td class={cellClass(feature.free)}>{renderValue(feature.free)}</td>
                <td class={cellClass(feature.pro)}>{renderValue(feature.pro)}</td>
                <td class={cellClass(feature.coach)}>{renderValue(feature.coach)}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </div>
</section>
