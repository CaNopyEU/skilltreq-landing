---
import ThemeToggle from './ThemeToggle.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import type { Locale } from '../i18n/translations';
import { useTranslations } from '../i18n/translations';

interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;
const t = useTranslations(locale);
---

<header class="sticky top-0 z-50 border-b border-border bg-page/80 backdrop-blur-lg">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3 sm:px-6">
    <a href={`/${locale}/`} class="flex items-center gap-2 text-primary font-semibold">
      <img src="/icon.svg" alt="SkillTreq" width="28" height="28" />
      <span class="hidden sm:inline">SkillTreq</span>
    </a>

    <div class="flex items-center gap-3">
      <ThemeToggle locale={locale} />
      <LanguageSwitcher locale={locale} currentPath={currentPath} />
    </div>
  </div>
</header>
