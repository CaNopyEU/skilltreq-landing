---
import ThemeToggle from './ThemeToggle.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import type { Locale } from '../i18n/translations';
import { useTranslations } from '../i18n/translations';

interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;
const t = useTranslations(locale);
---

<header class="sticky top-0 z-50 border-b border-border bg-page/80 backdrop-blur-lg">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3 sm:px-6">
    <a href={`/${locale}/`} class="flex items-center gap-2 text-primary font-semibold">
      <img src="/icon.svg" alt="Skilltreq" width="28" height="28" />
      <span class="hidden sm:inline">Skilltreq</span>
    </a>

    <nav class="hidden items-center gap-6 text-sm md:flex" aria-label="Main navigation">
      <a href={`/${locale}/`} class="text-body transition-colors hover:text-primary"
        >{t('nav.home')}</a
      >
      <a href={`/${locale}/pricing`} class="text-body transition-colors hover:text-primary"
        >{t('nav.pricing')}</a
      >
    </nav>

    <div class="flex items-center gap-3">
      <ThemeToggle locale={locale} />
      <LanguageSwitcher locale={locale} currentPath={currentPath} />

      <!-- Mobile menu button -->
      <button
        type="button"
        class="rounded-md p-2 text-body hover:text-primary md:hidden"
        aria-label="Open menu"
        data-mobile-menu-toggle
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          ><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"
          ></line><line x1="3" y1="18" x2="21" y2="18"></line></svg
        >
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <nav
    class="hidden border-t border-border px-4 py-3 md:hidden"
    aria-label="Mobile navigation"
    data-mobile-menu
  >
    <a href={`/${locale}/`} class="block py-2 text-body transition-colors hover:text-primary"
      >{t('nav.home')}</a
    >
    <a href={`/${locale}/pricing`} class="block py-2 text-body transition-colors hover:text-primary"
      >{t('nav.pricing')}</a
    >
  </nav>
</header>

<script>
  document.querySelectorAll('[data-mobile-menu-toggle]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const menu = btn.closest('header')?.querySelector('[data-mobile-menu]');
      menu?.classList.toggle('hidden');
    });
  });
</script>
