---
import type { Locale } from '../i18n/translations';
import { useTranslations } from '../i18n/translations';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const platforms = [
  {
    id: 'ios',
    title: t('pwa.ios.title'),
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>`,
    steps: [
      t('pwa.ios.step1'),
      t('pwa.ios.step2'),
      t('pwa.ios.step3'),
    ],
  },
  {
    id: 'android',
    title: t('pwa.android.title'),
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>`,
    steps: [
      t('pwa.android.step1'),
      t('pwa.android.step2'),
      t('pwa.android.step3'),
    ],
  },
  {
    id: 'desktop',
    title: t('pwa.desktop.title'),
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
    steps: [
      t('pwa.desktop.step1'),
      t('pwa.desktop.step2'),
    ],
  },
] as const;
---

<section class="py-20 sm:py-28">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-primary sm:text-4xl">
        {t('pwa.heading')}
      </h2>
      <p class="mt-4 text-lg text-secondary">
        {t('pwa.subtitle')}
      </p>
    </div>

    <div class="mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {
        platforms.map((platform) => (
          <div class="rounded-xl border border-border bg-page p-6">
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-accent/10 text-accent">
              <Fragment set:html={platform.icon} />
            </div>
            <h3 class="text-lg font-semibold text-primary">{platform.title}</h3>
            <ol class="mt-4 space-y-3">
              {platform.steps.map((step, i) => (
                <li class="flex gap-3 text-sm leading-relaxed text-body">
                  <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-accent/10 text-xs font-semibold text-accent">
                    {i + 1}
                  </span>
                  <span>{step}</span>
                </li>
              ))}
            </ol>
          </div>
        ))
      }
    </div>
  </div>
</section>
