---
import type { Locale } from '../i18n/translations';
import { useTranslations } from '../i18n/translations';
import SkillTreeDemo from './demo/SkillTreeDemo.vue';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

// Build demo translations object for Vue island
const demoKeys = [
  'demo.skill.dead-hang',
  'demo.skill.active-hang',
  'demo.skill.pull-up',
  'demo.skill.chest-to-bar',
  'demo.skill.muscle-up',
  'demo.skill.l-hang',
  'demo.skill.push-up',
  'demo.skill.diamond-pu',
  'demo.skill.pike-pu',
  'demo.skill.hspu',
  'demo.skill.pseudo-planche-pu',
  'demo.skill.planche-lean',
  'demo.skill.plank',
  'demo.skill.hollow-body',
  'demo.skill.l-sit',
  'demo.skill.v-sit',
  'demo.skill.side-plank',
  'demo.skill.human-flag',
  'demo.status.locked',
  'demo.status.unlocked',
  'demo.status.in_progress',
  'demo.status.completed',
  'demo.status.mastered',
  'demo.tooltip.cta',
] as const;

const demoTranslations: Record<string, string> = {};
for (const key of demoKeys) {
  demoTranslations[key] = t(key as any);
}
---

<section class="relative overflow-hidden py-20 sm:py-28 lg:py-36">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="mx-auto max-w-3xl text-center">
      <h1 class="text-4xl font-bold tracking-tight text-primary sm:text-5xl lg:text-6xl">
        {t('hero.headline')}
      </h1>
      <p class="mt-6 text-lg text-secondary sm:text-xl">
        {t('hero.subtitle')}
      </p>
      <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a
          href="https://www.skilltreq.app/"
          class="btn-primary text-base"
          data-umami-event="cta-try-free"
        >
          {t('hero.cta')}
        </a>
        <a href="#features" class="btn-secondary text-base">
          {t('hero.secondary')}
        </a>
      </div>
    </div>

    <!-- Desktop: interactive demo -->
    <div class="hidden md:block mx-auto mt-16 max-w-4xl">
      <div
        class="aspect-video rounded-xl border border-border shadow-lg overflow-hidden bg-surface"
      >
        <SkillTreeDemo client:visible translations={demoTranslations} />
      </div>
    </div>

    <!-- Mobile: static screenshot (preserves LCP) -->
    <div class="md:hidden mx-auto mt-16 max-w-4xl">
      <img
        src="/screenshots/hero-skill-tree.webp"
        alt="SkillTreq skill tree — dependency graph showing calisthenics skill progression"
        width="1600"
        height="900"
        loading="eager"
        fetchpriority="high"
        class="rounded-xl border border-border shadow-lg"
      />
    </div>
  </div>
</section>
