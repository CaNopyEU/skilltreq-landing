---
import type { Locale } from '../i18n/translations';
import { useTranslations } from '../i18n/translations';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section class="relative overflow-hidden py-20 sm:py-28 lg:py-36">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="mx-auto max-w-3xl text-center">
      <h1 class="text-4xl font-bold tracking-tight text-primary sm:text-5xl lg:text-6xl">
        {t('hero.headline')}
      </h1>
      <p class="mt-6 text-lg text-secondary sm:text-xl">
        {t('hero.subtitle')}
      </p>
      <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href="https://www.skilltreq.app/" class="btn-primary text-base" data-umami-event="cta-try-free">
          {t('hero.cta')}
        </a>
        <a href="#features" class="btn-secondary text-base">
          {t('hero.secondary')}
        </a>
      </div>
    </div>

    <!-- Hero screenshot -->
    <div class="mx-auto mt-16 max-w-4xl">
      <img
        src="/screenshots/hero-skill-tree.png"
        alt="SkillTreq skill tree — dependency graph showing calisthenics skill progression"
        width="1600"
        height="900"
        loading="eager"
        class="rounded-xl border border-border shadow-lg"
      />
    </div>
  </div>
</section>
