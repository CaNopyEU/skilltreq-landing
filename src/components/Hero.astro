---
import type { Locale } from '../i18n/translations';
import { useTranslations } from '../i18n/translations';
import SkillTreeDemo from './demo/SkillTreeDemo.vue';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

// Build demo translations object for Vue island
const demoKeys = [
  'demo.skill.dead-hang',
  'demo.skill.active-hang',
  'demo.skill.pull-up',
  'demo.skill.chest-to-bar',
  'demo.skill.muscle-up',
  'demo.skill.l-hang',
  'demo.skill.push-up',
  'demo.skill.diamond-pu',
  'demo.skill.pike-pu',
  'demo.skill.hspu',
  'demo.skill.pseudo-planche-pu',
  'demo.skill.planche-lean',
  'demo.skill.plank',
  'demo.skill.hollow-body',
  'demo.skill.l-sit',
  'demo.skill.v-sit',
  'demo.skill.side-plank',
  'demo.skill.human-flag',
  'demo.status.locked',
  'demo.status.unlocked',
  'demo.status.in_progress',
  'demo.status.completed',
  'demo.status.mastered',
  'demo.tooltip.cta',
] as const;

const demoTranslations: Record<string, string> = {};
for (const key of demoKeys) {
  demoTranslations[key] = t(key as any);
}
---

<section class="relative overflow-hidden py-20 sm:py-28 lg:py-36">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="mx-auto max-w-3xl text-center">
      <h1
        class="hero-enter-lcp text-4xl font-bold tracking-tight text-primary sm:text-5xl lg:text-6xl"
        style="--delay: 0ms"
      >
        {t('hero.headline.pre')}<span class="text-gradient">{t('hero.headline.accent')}</span>{
          t('hero.headline.post')
        }
      </h1>
      <p class="hero-enter mt-6 text-lg text-secondary sm:text-xl" style="--delay: 120ms">
        {t('hero.subtitle')}
      </p>
      <div
        class="hero-enter mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center"
        style="--delay: 240ms"
      >
        <a
          href="https://www.skilltreq.app/"
          class="btn-primary text-base"
          data-umami-event="cta-try-free"
        >
          {t('hero.cta')}
        </a>
        <a href="#features" class="btn-secondary text-base">
          {t('hero.secondary')}
        </a>
      </div>
    </div>

    <!-- Desktop: full tree -->
    <div class="hero-enter relative hidden md:block mx-auto mt-16 max-w-4xl" style="--delay: 400ms">
      <div class="demo-glow"></div>

      <!-- Floating badges -->
      <div class="demo-badge" style="top: -0.75rem; left: -2rem; --delay: 600ms; --float-delay: 0s">
        <span class="demo-badge-dot" style="background: var(--status-mastered)"></span>
        {t('demo.status.mastered')}
      </div>
      <div
        class="demo-badge"
        style="top: 1.5rem; right: -2.5rem; --delay: 700ms; --float-delay: 1s"
      >
        <span class="demo-badge-dot" style="background: var(--status-in-progress)"></span>
        {t('demo.status.in_progress')}
      </div>
      <div
        class="demo-badge"
        style="bottom: 2rem; left: -2.75rem; --delay: 800ms; --float-delay: 0.5s"
      >
        <span class="demo-badge-dot" style="background: var(--status-completed)"></span>
        {t('demo.status.completed')}
      </div>
      <div
        class="demo-badge"
        style="bottom: -0.5rem; right: -1.5rem; --delay: 900ms; --float-delay: 1.5s"
      >
        <span class="demo-badge-dot" style="background: var(--status-locked)"></span>
        {t('demo.status.locked')}
      </div>

      <div
        class="relative z-[1] aspect-video rounded-xl border border-border shadow-lg overflow-hidden bg-surface"
      >
        <SkillTreeDemo client:only="vue" translations={demoTranslations} />
      </div>
    </div>

    <!-- Mobile: single branch, taller -->
    <div class="hero-enter relative md:hidden mx-auto mt-12 max-w-sm" style="--delay: 400ms">
      <div class="demo-glow"></div>
      <div
        class="relative z-[1] aspect-[3/4] rounded-xl border border-border shadow-lg overflow-hidden bg-surface"
      >
        <SkillTreeDemo client:only="vue" translations={demoTranslations} compact />
      </div>
    </div>
  </div>
</section>
