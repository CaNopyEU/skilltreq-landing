---
import type { Locale } from '../i18n/translations';
import { useTranslations } from '../i18n/translations';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const year = new Date().getFullYear().toString();
---

<footer class="border-t border-border bg-surface">
  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
    <div class="flex flex-col items-center gap-6 sm:flex-row sm:justify-between">
      <div class="flex items-center gap-2">
        <img src="/logo.svg" alt="SkillTreq" width="24" height="24" />
        <span class="text-sm font-medium text-primary">SkillTreq</span>
      </div>

      <nav class="flex flex-wrap justify-center gap-6 text-sm" aria-label="Footer navigation">
        <a href={`/${locale}/privacy`} class="text-body transition-colors hover:text-primary"
          >{t('nav.privacy')}</a
        >
        <a href={`/${locale}/terms`} class="text-body transition-colors hover:text-primary"
          >{t('nav.terms')}</a
        >
        <a
          href="https://ko-fi.com/skilltreq"
          target="_blank"
          rel="noopener noreferrer"
          class="text-body transition-colors hover:text-primary">{t('footer.support')}</a
        >
      </nav>
    </div>

    <div class="mt-8 flex flex-col items-center gap-2 text-center text-sm text-text-muted">
      <p>{t('footer.tagline')}</p>
      <p>{t('footer.beta')}</p>
      <p>
        <a
          href="mailto:hello@skilltreq.com"
          class="text-text-muted transition-colors hover:text-primary"
          >hello@skilltreq.com</a
        >
      </p>
      <p>{t('footer.copyright', { year })}</p>
    </div>
  </div>
</footer>
